# ── Required ──────────────────────────────────────────────────────────────────
# Get a free key at https://console.groq.com (no credit card)
GROQ_API_KEY=your_groq_key_here

# ── Optional — improves results, still free ────────────────────────────────────
# CourtListener: free token at https://www.courtlistener.com/sign-in/
# Raises limit from anonymous to 5,000 requests/day
COURTLISTENER_TOKEN=

# OpenFDA: free key at https://open.fda.gov/apis/authentication/
# Raises rate limit from 40 to 240 requests/minute
OPENFDA_API_KEY=

# ── Production (set in Railway dashboard) ─────────────────────────────────────
# Your Vercel frontend URL — added to CORS allowlist
FRONTEND_URL=https://your-app.vercel.app
